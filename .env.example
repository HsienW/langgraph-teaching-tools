# OpenAI settings

OPENAI_API_KEY="<openai-api-key>"
OPENAI_BASE_URL="<openai-base-url>" # Optional. Use only if your OpenAI-compatible endpoint is not the default.

# LangSmith settings
# Optional. Enable these if you want tracing and experiment tracking.

LANGSMITH_API_KEY="<langsmith-api-key>"
LANGSMITH_ENDPOINT="<langsmith-endpoint>" # Optional. Defaults to https://api.smith.langchain.com for LangSmith Cloud.
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="langgraph-101"

# Azure OpenAI settings
# Optional. Use these only if you are connecting through Azure OpenAI.

AZURE_OPENAI_API_KEY="<azure-openai-api-key>"
AZURE_OPENAI_ENDPOINT="<azure-openai-endpoint>"
AZURE_OPENAI_API_VERSION=""

# Anthropic settings

ANTHROPIC_API_KEY="<anthropic-api-key>"

# AWS Bedrock settings

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION_NAME=""
AWS_MODEL_ARN=""
